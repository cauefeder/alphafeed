# Alpha Feed — environment variables
# Copy to .env and fill in your values

# ── PolyTraders settings (passed through to the adapter) ──────────────
POLYTRADERS_TOP_N=25
POLYTRADERS_BANKROLL=100
POLYTRADERS_TIME_PERIOD=WEEK

# ── Frontend backend URL (optional — defaults to same-origin via Vite proxy) ──
# Set this when deploying frontend and backend on separate hosts
# VITE_API_BASE=https://your-backend.onrender.com
