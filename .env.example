# Alpha Feed — environment variables
# Copy this file to .env and fill in your values.
# The app works without any of these — they are all optional.

# ── Adapter: path to sibling projects ─────────────────────────────────
# Required only when AlphaFeed is NOT in the same parent folder as
# PolyTraders / HedgePoly (e.g. standalone clone on Linux/macOS).
#
# Linux/macOS examples:
#   POLYTRADERS_DIR=/home/user/projects/PolyTraders
#   HEDGEPOLY_DIR=/home/user/projects/HedgePoly/prediction-market-analysis
#
# Windows examples:
#   POLYTRADERS_DIR=C:\Users\user\projects\PolyTraders
#   HEDGEPOLY_DIR=C:\Users\user\projects\HedgePoly\prediction-market-analysis
#
# POLYTRADERS_DIR=
# HEDGEPOLY_DIR=

# ── PolyTraders adapter settings ──────────────────────────────────────
POLYTRADERS_TOP_N=25
POLYTRADERS_BANKROLL=100
POLYTRADERS_TIME_PERIOD=WEEK

# ── Backend CORS (production) ──────────────────────────────────────────
# Set to your frontend URL(s) in production. "*" is fine for local dev.
# ALLOWED_ORIGINS=https://your-app.vercel.app

# ── Frontend backend URL ───────────────────────────────────────────────
# Set when frontend and backend are on separate hosts (Vercel + Render).
# VITE_API_BASE=https://your-backend.onrender.com
